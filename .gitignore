# Frontend ignores
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env*
frontend/next-env.d.ts
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*

# Backend ignores
backend/node_modules/
backend/vendor/
backend/public/build/
backend/public/hot/
backend/public/storage/
backend/storage/*.key
backend/.env
backend/.env.backup
backend/.env.production
backend/.phpunit.result.cache
backend/Homestead.json
backend/Homestead.yaml
backend/auth.json

# Root ignores
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/.fleet
/.idea
/.vscode

# Ignore php phar files
/composer.phar
